@page "/estudiantes"
@rendermode InteractiveServer
@using LP3.BlazorServer.Shared.DTOs
@using LP3.BlazorServer.Application.Services
@using LP3.BlazorServer.Domain.Enums

@inject IEstudianteService EstudianteService

<div class="container mt-5">
    <h1>📚 Gestión de Estudiantes</h1>
    <p class="text-muted">Aquí puedes crear, consultar, editar y eliminar estudiantes</p>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN 1: BÚSQUEDA POR MATRÍCULA
         ══════════════════════════════════════════════════ -->
    <div class="card mb-4">
        <div class="card-body">
            <h4>🔍 Buscar Estudiante por Matrícula</h4>

            <div class="input-group">
                <input
                    type="text"
                    class="form-control"
                    @bind="matriculaBusqueda"
                    @bind:event="oninput"
                    placeholder="Ej: 2024001" />
                <button class="btn btn-primary" @onclick="BuscarPorMatricula">
                    Buscar
                </button>
                @* Botón para limpiar la búsqueda *@
                @if (estudianteBuscado != null || !string.IsNullOrEmpty(mensajeBusqueda))
                {
                    <button class="btn btn-outline-secondary" @onclick="LimpiarBusqueda">
                        ✕ Limpiar
                    </button>
                }
            </div>

            @* Mensaje de error de búsqueda — separado del resto de mensajes *@
            @if (!string.IsNullOrEmpty(mensajeBusqueda))
            {
                <div class="alert alert-danger mt-3">
                    @mensajeBusqueda
                </div>
            }

            @* Resultado de búsqueda exitosa *@
            @if (estudianteBuscado != null)
            {
                <div class="alert alert-info mt-3">
                    <strong>✓ Encontrado:</strong>
                    @estudianteBuscado.Nombre @estudianteBuscado.Apellido
                    — Matrícula: <strong>@estudianteBuscado.Matricula</strong>
                    (ID: @estudianteBuscado.Id)
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN 2: REGISTRAR NUEVO ESTUDIANTE
         ══════════════════════════════════════════════════ -->
    <div class="card mb-4">
        <div class="card-body">
            <h4>➕ Registrar Nuevo Estudiante</h4>

            <EditForm FormName="registroEstudianteForm" Model="nuevoEstudiante" OnValidSubmit="RegistrarEstudiante">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="nombre" class="form-label">Nombre:</label>
                        <InputText id="nombre" @bind-Value="nuevoEstudiante.Nombre"
                                   class="form-control"
                                   placeholder="Ej: Juan" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="apellido" class="form-label">Apellido:</label>
                        <InputText id="apellido" @bind-Value="nuevoEstudiante.Apellido"
                                   class="form-control"
                                   placeholder="Ej: Pérez" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="matricula-new" class="form-label">Matrícula:</label>
                        <InputText id="matricula-new" @bind-Value="nuevoEstudiante.Matricula"
                                   class="form-control"
                                   placeholder="Ej: 2024001" />
                    </div>
                    @* <div class="col-md-6 mb-3">
                        <label for="email-new" class="form-label">Email:</label>
                        <InputText id="email-new" type="email" @bind-Value="nuevoEstudiante.Email"
                                   class="form-control"
                                   placeholder="Ej: juan@example.com" />
                    </div> *@
                </div>

                <button type="submit" class="btn btn-success">
                    ✓ Guardar Estudiante
                </button>
            </EditForm>

            @* Mensaje exclusivo para operaciones de registro/edición/eliminación *@
            @if (!string.IsNullOrEmpty(mensajeOperacion))
            {
                <div class="alert mt-3 @(mensajeOperacion.StartsWith("✅") ? "alert-success" : "alert-danger")">
                    @mensajeOperacion
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN 3: TABLA DE ESTUDIANTES
         ══════════════════════════════════════════════════ -->
    <div class="card">
        <div class="card-body">
            <h4>📊 Estudiantes Registrados (@(estudiantes?.Count ?? 0))</h4>

            @if (estudiantes == null || estudiantes.Count == 0)
            {
                <div class="alert alert-info">
                    No hay estudiantes registrados aún.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Apellido</th>
                                <th>Matrícula</th>
                                @* <th>Email</th> *@
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var est in estudiantes)
                            {
                                <tr>
                                    <td>@est.Id</td>
                                    <td>@est.Nombre</td>
                                    <td>@est.Apellido</td>
                                    <td><strong>@est.Matricula</strong></td>
                                    @* <td>@est.Email</td> *@
                                    <td>
                                        <button class="btn btn-sm btn-warning"
                                                @onclick="() => CargarParaEditar(est)">
                                            ✏️ Editar
                                        </button>
                                        <button class="btn btn-sm btn-danger"
                                                @onclick="() => ConfirmarEliminar(est)">
                                            🗑️ Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         SECCIÓN 4: FORMULARIO DE EDICIÓN
         (aparece debajo de la tabla al hacer clic en Editar)
         ══════════════════════════════════════════════════ -->
    @if (editandoEstudiante != null)
    {
        <div class="card mt-4 border-warning">
            <div class="card-body">
                <h4>✏️ Editar Estudiante</h4>

                <EditForm Model="editandoEstudiante" OnValidSubmit="GuardarCambios">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="nombre-edit" class="form-label">Nombre:</label>
                            <InputText id="nombre-edit" @bind-Value="editandoEstudiante.Nombre"
                                       class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="apellido-edit" class="form-label">Apellido:</label>
                            <InputText id="apellido-edit" @bind-Value="editandoEstudiante.Apellido"
                                       class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        @* <div class="col-md-6 mb-3">
                            <label for="email-edit" class="form-label">Email:</label>
                            <InputText id="email-edit" @bind-Value="editandoEstudiante.Email"
                                       class="form-control" />
                        </div> *@

                        <div class="col-md-6 mb-3">
                            <label for="matricula-edit" class="form-label">
                                Matrícula <span class="text-muted">(no editable)</span>:
                            </label>
                            <InputText id="matricula-edit" @bind-Value="editandoEstudiante.Matricula"
                                       class="form-control" disabled />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        ✓ Guardar Cambios
                    </button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CancelarEdicion">
                        ✕ Cancelar
                    </button>
                </EditForm>
            </div>
        </div>
    }

    <!-- ══════════════════════════════════════════════════
         SECCIÓN 5: CONFIRMACIÓN DE ELIMINACIÓN
         (aparece junto a la tabla, muestra nombre del estudiante)
         ══════════════════════════════════════════════════ -->
    @if (mostrarConfirmacionEliminar && estudianteAEliminar != null)
    {
        <div class="card mt-4 border-danger">
            <div class="card-body">
                <div class="alert alert-danger mb-0" role="alert">
                    <h5>⚠️ Confirmar Eliminación</h5>
                    <p>
                        ¿Está seguro de que desea eliminar al estudiante
                        <strong>@estudianteAEliminar.Nombre @estudianteAEliminar.Apellido</strong>
                        (Matrícula: <strong>@estudianteAEliminar.Matricula</strong>)?
                    </p>
                    <p class="mb-3" style="font-size: 0.9em;">
                        <strong>Esta acción no se puede deshacer.</strong>
                    </p>

                    <button class="btn btn-danger" @onclick="EliminarEstudiante">
                        Sí, Eliminar Permanentemente
                    </button>
                    <button class="btn btn-secondary ms-2" @onclick="CancelarEliminar">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {

    // ── Datos principales ────────────────────────────────────────────────────
    private ICollection<EstudianteDto> estudiantes = [];

    // ── Mensajes separados por área (evita que se pisen entre sí) ───────────
    private string mensajeBusqueda  = string.Empty;   // solo para búsqueda
    private string mensajeOperacion = string.Empty;   // registro / edición / eliminación

    // ── Variables de búsqueda ────────────────────────────────────────────────
    private string matriculaBusqueda  = string.Empty;
    private EstudianteDto? estudianteBuscado;

    // ── Variables de registro ────────────────────────────────────────────────
    private EstudianteDto nuevoEstudiante = new();

    // ── Variables de edición ─────────────────────────────────────────────────
    private EstudianteDto? editandoEstudiante;
    private int idEstudianteEditando = 0;

    // ── Variables de eliminación ─────────────────────────────────────────────
    private bool mostrarConfirmacionEliminar = false;
    private EstudianteDto? estudianteAEliminar;   // CORREGIDO: guardamos el objeto completo
                                                  // para mostrar nombre en la confirmación

    // ════════════════════════════════════════════════════════════════════════
    // CICLO DE VIDA
    // ════════════════════════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await CargarEstudiantes();
    }

    private async Task CargarEstudiantes()
    {
        estudiantes = await EstudianteService.GetAll();
    }

    // ════════════════════════════════════════════════════════════════════════
    // BÚSQUEDA
    // ════════════════════════════════════════════════════════════════════════

    private async Task BuscarPorMatricula()
    {
        // Limpiar estado anterior de búsqueda antes de cada intento
        estudianteBuscado = null;
        mensajeBusqueda   = string.Empty;

        if (string.IsNullOrWhiteSpace(matriculaBusqueda))
        {
            mensajeBusqueda = "❌ Por favor ingresa una matrícula para buscar.";
            return;
        }

        estudianteBuscado = await EstudianteService.GetByMatriculaAsync(matriculaBusqueda);

        if (estudianteBuscado == null)
        {
            mensajeBusqueda = $"❌ No se encontró un estudiante con la matrícula \"{matriculaBusqueda}\".";
        }
    }

    // CORREGIDO: limpia todos los campos relacionados con la búsqueda
    private void LimpiarBusqueda()
    {
        matriculaBusqueda = string.Empty;
        estudianteBuscado = null;
        mensajeBusqueda   = string.Empty;
    }

    // ════════════════════════════════════════════════════════════════════════
    // REGISTRO
    // ════════════════════════════════════════════════════════════════════════

    private async Task RegistrarEstudiante()
    {
        mensajeOperacion = string.Empty;

        if (string.IsNullOrWhiteSpace(nuevoEstudiante.Nombre)    ||
            string.IsNullOrWhiteSpace(nuevoEstudiante.Apellido)  ||
            string.IsNullOrWhiteSpace(nuevoEstudiante.Matricula)
            // || string.IsNullOrWhiteSpace(nuevoEstudiante.Email)
            )
        {
            mensajeOperacion = "⚠️ Por favor completa todos los campos requeridos.";
            return;
        }

        bool resultado = await EstudianteService.CreateAsync(nuevoEstudiante);

        if (resultado)
        {
            mensajeOperacion = "✅ Estudiante registrado exitosamente.";
            nuevoEstudiante  = new();
            await CargarEstudiantes();
        }
        else
        {
            mensajeOperacion = "❌ Error al registrar el estudiante. Verifica que la matrícula sea única.";
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // EDICIÓN
    // ════════════════════════════════════════════════════════════════════════

    private void CargarParaEditar(EstudianteDto estudiante)
    {
        mensajeOperacion = string.Empty;

        // Copiamos los valores para no modificar el objeto original de la lista
        editandoEstudiante = new EstudianteDto
        {
            Id       = estudiante.Id,
            Nombre   = estudiante.Nombre,
            Apellido = estudiante.Apellido,
            Matricula = estudiante.Matricula
            // Email = estudiante.Email
        };
        idEstudianteEditando = estudiante.Id;
    }

    private async Task GuardarCambios()
    {
        if (editandoEstudiante == null) return;

        bool resultado = await EstudianteService.UpdateAsync(idEstudianteEditando, editandoEstudiante);

        if (resultado)
        {
            mensajeOperacion     = "✅ Estudiante actualizado exitosamente.";
            editandoEstudiante   = null;
            idEstudianteEditando = 0;
            await CargarEstudiantes();
        }
        else
        {
            mensajeOperacion = "❌ Error al actualizar el estudiante.";
        }
    }

    private void CancelarEdicion()
    {
        editandoEstudiante   = null;
        idEstudianteEditando = 0;
        mensajeOperacion     = string.Empty;
    }

    // ════════════════════════════════════════════════════════════════════════
    // ELIMINACIÓN
    // ════════════════════════════════════════════════════════════════════════

    // CORREGIDO: recibe el objeto completo en lugar de solo el ID,
    // para poder mostrar el nombre en el cuadro de confirmación
    private void ConfirmarEliminar(EstudianteDto estudiante)
    {
        estudianteAEliminar          = estudiante;
        mostrarConfirmacionEliminar  = true;
        mensajeOperacion             = string.Empty;
    }

    private async Task EliminarEstudiante()
    {
        if (estudianteAEliminar == null) return;

        bool resultado = await EstudianteService.DeleteAsync(estudianteAEliminar.Id);

        if (resultado)
        {
            mensajeOperacion            = "✅ Estudiante eliminado exitosamente.";
            mostrarConfirmacionEliminar = false;
            estudianteAEliminar         = null;
            await CargarEstudiantes();
        }
        else
        {
            // CORREGIDO: cerramos el cuadro aunque falle para no dejarlo colgado
            mensajeOperacion            = "❌ Error al eliminar el estudiante. Intenta nuevamente.";
            mostrarConfirmacionEliminar = false;
            estudianteAEliminar         = null;
        }
    }

    private void CancelarEliminar()
    {
        mostrarConfirmacionEliminar = false;
        estudianteAEliminar         = null;
    }
}
